// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  STARTER
  GROWTH
  SCALE
}

enum PlatformId {
  FACEBOOK
  INSTAGRAM
  X
  LINKEDIN
  TIKTOK
  YOUTUBE
}

enum ContentType {
  TEXT_POST
  IMAGE_POST
  CAROUSEL
  STORY
  VIDEO
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
}

enum Ratio {
  PORTRAIT
  SQUARE
  LANDSCAPE
}

enum Tone {
  CONFIDENT
  PLAYFUL
  INFORMATIVE
}

model User {
  id                   String   @id @default(cuid())
  email                String   @unique
  passwordHash         String
  plan                 Plan     @default(STARTER)
  billingCycle         String   @default("monthly")
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  subscriptionStatus   String?
  onboardingDismissed  Boolean  @default(false)
  suspended            Boolean  @default(false)
  referralCode         String   @unique @default(cuid())
  referredByUserId     String?
  referredByUser       User?    @relation("Referrals", fields: [referredByUserId], references: [id])
  referrals            User[]   @relation("Referrals")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  connections     SocialConnection[]
  automationRules AutomationRule[]
  settings        UserSettings?
  posts           Post[]
  videoRenderLogs VideoRenderLog[]
  referralCredits ReferralCredit[]
  passwordResetTokens PasswordResetToken[]
}

// Single-use, expiring token for the forgot-password flow. The raw token is
// only ever emailed once -- only its hash is stored, so a leaked DB dump
// can't be used to reset anyone's password.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// Append-only attempt log for rate-limiting login/register/reset-request,
// mirroring VideoRenderLog/AutomationFireLog's idiom of a small purpose-built
// Postgres table instead of introducing Redis for this.
model AuthAttempt {
  id        String   @id @default(cuid())
  kind      String
  ip        String
  email     String?
  succeeded Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([ip, kind, createdAt])
  @@index([email, kind, createdAt])
}

// Append-only bonus-generation ledger, mirrors VideoRenderLog's role as the
// source of truth for usage: `amount - consumed` summed across all rows is
// the bonus quota still available, layered on top of the plan's base limit.
model ReferralCredit {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  reason    String
  consumed  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([userId])
}

model SocialConnection {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  platformId  PlatformId
  connected   Boolean    @default(false)
  handle      String?
  // Real OAuth connectors (Meta, TikTok, ...) populate these; tokens are
  // never sent to the client, only used server-side by the connector.
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  externalId     String?
  connectedAt    DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([userId, platformId])
}

model AutomationRule {
  id         String     @id @default(cuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  platformId PlatformId
  enabled    Boolean    @default(false)
  times      String[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  fireLogs AutomationFireLog[]

  @@unique([userId, platformId])
}

model UserSettings {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  autoTrending          Boolean  @default(true)
  notifyOnPublish       Boolean  @default(true)
  notifyOnFailure       Boolean  @default(true)
  notifyWeeklyRecap     Boolean  @default(true)
  brandIndustry         String?
  brandToneDescription  String?  @db.Text
  brandExamplePosts     String[] @default([])
}

model Post {
  id                     String      @id @default(cuid())
  userId                 String
  user                   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  platformId             PlatformId
  text                   String
  status                 PostStatus  @default(DRAFT)
  type                   ContentType @default(TEXT_POST)
  tone                   Tone?
  duration               String?
  ratio                  Ratio?
  videoUrl               String?
  imageUrl               String?
  externalPostId         String?
  scheduledAt            DateTime?
  publishedAt            DateTime?
  failureReason          String?
  sourceAutomationRuleId String?
  trendLabel             String?
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  metrics PostMetric[]

  @@index([userId, status, scheduledAt])
}

// One row per metrics fetch (a time series, not a mutable counter) so a
// future recap email or trend chart can use history; "current" = latest row
// per post. Only populated for posts published through a real connector.
model PostMetric {
  id          String   @id @default(cuid())
  postId      String
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  impressions Int?
  likes       Int?
  comments    Int?
  shares      Int?
  views       Int?
  fetchedAt   DateTime @default(now())

  @@index([postId, fetchedAt])
}

// Idempotency guard for the automation engine: one row per (rule, calendar day, slot)
// prevents double-firing when the cron trigger overlaps or retries.
model AutomationFireLog {
  id               String         @id @default(cuid())
  automationRuleId String
  automationRule   AutomationRule @relation(fields: [automationRuleId], references: [id], onDelete: Cascade)
  fireDate         DateTime       @db.Date
  slot             String
  createdAt        DateTime       @default(now())

  @@unique([automationRuleId, fireDate, slot])
}

// One row per accepted video-render job. Counted against the user's plan's
// monthly video allowance -- logged when a render job is accepted (i.e. real
// OpenAI cost is about to be incurred), independent of whether the resulting
// video is ever scheduled as a Post.
//
// contentHash + videoUrl double as a dedup cache: re-rendering the exact same
// script+ratio (e.g. an accidental double-click of "Re-render") returns the
// prior result for free instead of paying for a new image + narration set.
model VideoRenderLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentHash String
  jobId       String?
  videoUrl    String?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, contentHash])
}

// Fully separate identity space from User -- the admin portal has its own
// login and session mechanism, deliberately isolated from Auth.js. Every row
// is a full admin; no roles/permissions, kept minimal on purpose.
model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Append-only run history for the cron routes (publish/metrics/weekly-recap),
// which previously persisted nothing -- surfaced on the admin health page.
model CronRun {
  id        String   @id @default(cuid())
  name      String
  ok        Boolean
  summary   Json?
  error     String?
  createdAt DateTime @default(now())

  @@index([name, createdAt])
}
