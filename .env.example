# Neon Postgres — pooled connection string, used by the app at runtime (src/lib/prisma.ts)
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/smw?sslmode=require"

# Neon Postgres — direct (non-pooled) connection string, used by Prisma Migrate (prisma.config.ts)
DIRECT_DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/smw?sslmode=require"

# Auth.js — generate with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET=""

# Anthropic Claude API — https://console.anthropic.com/
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-5"

# Shared secret the cron trigger (GitHub Actions) must send to /api/cron/publish
CRON_SECRET=""

# Stripe — https://dashboard.stripe.com/apikeys (test mode secret key, starts with sk_test_)
STRIPE_SECRET_KEY=""
# From `npm run stripe:setup` output (billing portal configuration it creates)
STRIPE_PORTAL_CONFIGURATION_ID=""
# From the webhook endpoint's "Signing secret" in the Stripe dashboard, or the
# `endpoint.secret` printed when creating it via the API (only shown once)
STRIPE_WEBHOOK_SECRET=""

# Vercel Blob — stores rendered video files (vercel blob create-store --access public)
BLOB_READ_WRITE_TOKEN=""

# Remotion video renderer service (video-renderer/), deployed on Railway
RENDERER_URL=""
RENDER_SECRET=""
