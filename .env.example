# Neon Postgres — pooled connection string, used by the app at runtime (src/lib/prisma.ts)
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/smw?sslmode=require"

# Neon Postgres — direct (non-pooled) connection string, used by Prisma Migrate (prisma.config.ts)
DIRECT_DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/smw?sslmode=require"

# Auth.js — generate with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET=""

# Signs the separate admin-portal session cookie (src/lib/admin-auth.ts) --
# fully independent of AUTH_SECRET/Auth.js, do not reuse that value.
# Generate with: openssl rand -base64 32
ADMIN_SESSION_SECRET=""

# Anthropic Claude API — https://console.anthropic.com/
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-5"

# OpenAI — used directly by the main app for the standalone thumbnail
# generator (video-renderer/ has its own separate copy of this key for
# per-beat video imagery)
OPENAI_API_KEY=""

# Shared secret the cron trigger (GitHub Actions) must send to /api/cron/publish
CRON_SECRET=""

# Stripe — https://dashboard.stripe.com/apikeys (test mode secret key, starts with sk_test_)
STRIPE_SECRET_KEY=""
# From `npm run stripe:setup` output (billing portal configuration it creates)
STRIPE_PORTAL_CONFIGURATION_ID=""
# From the webhook endpoint's "Signing secret" in the Stripe dashboard, or the
# `endpoint.secret` printed when creating it via the API (only shown once)
STRIPE_WEBHOOK_SECRET=""

# Vercel Blob — stores rendered video files (vercel blob create-store --access public)
BLOB_READ_WRITE_TOKEN=""

# Remotion video renderer service (video-renderer/), deployed on Railway
RENDERER_URL=""
RENDER_SECRET=""

# Base URL of this app — must exactly match the OAuth redirect URIs configured
# in each platform's developer dashboard.
APP_URL=""

# Meta (Facebook) app — developers.facebook.com, used for real Facebook Page OAuth
META_APP_ID=""
META_APP_SECRET=""

# TikTok app — developers.tiktok.com, used for real TikTok OAuth + Content Posting API
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""

# Instagram publishing reuses META_APP_ID/META_APP_SECRET above (same Meta
# app, Facebook Login) -- no separate credentials needed. Requires Meta
# business verification + the instagram_basic/instagram_content_publish
# permissions approved on the app before it can actually publish.

# X (Twitter) app — developer.x.com, OAuth 2.0 with PKCE. Requires the paid
# API tier for write access (tweet.write) before posting will work.
X_CLIENT_ID=""
X_CLIENT_SECRET=""

# LinkedIn app — linkedin.com/developers, requires Community Management API
# product access approval before w_member_social actually works.
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""

# Google Cloud OAuth client (YouTube Data API v3 enabled) — console.cloud.google.com.
# Requires the OAuth consent screen to pass verification for the
# youtube.upload scope before uploads will work for non-test users.
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""

# Resend — resend.com/api-keys, used for post-published/failed and weekly
# recap emails. RESEND_FROM must be on a domain verified in your Resend account.
RESEND_API_KEY=""
RESEND_FROM="SMW <notifications@yourdomain.com>"
